# Stealth gate (middleware). Omit or set to false to disable and serve the site publicly.
# When enabled, login uses a session cookie (cleared when the browser session ends) plus an 8h token.
GATE_ENABLED=true

# Password for the Access layer on the home page (not committed — set in Vercel env / local .env).
# Phase 1 example: gentlyphase1-2026
SITE_ACCESS_PASSWORD=

# Secret for signing the session cookie (min 32 random bytes recommended, e.g. openssl rand -base64 32).
GATE_JWT_SECRET=

# Chat widget — POST JSON { email, message, audience, pageUrl, submittedAt, source }
# when someone submits a question (Zapier, Slack, Make, Airtable, etc.)
LEAD_WEBHOOK_URL=
